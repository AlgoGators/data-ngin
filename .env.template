# Description: Template for environment variables
# Usage: Copy this file to .env in project root and fill in the values

# Databento API key
DATABENTO_API_KEY=databento-api-key

# Tiingo API keys (equities pipeline).
# The fetcher collects EVERY env var whose name starts with TIINGO_API_KEY and
# rotates across them, so adding capacity is purely an .env edit -- no code change.
# Each free-tier key allows ~50 requests/hour; the universe is ~570 symbols, so
# ~12 keys are needed to fetch it all in one daily run (ceil(symbols / 50)).
# IMPORTANT: only put ACTUAL API keys under the TIINGO_API_KEY* prefix. A non-key
# var like TIINGO_API_KEY_EXPIRY would be treated as a (bad) token and waste a slot.
TIINGO_API_KEY=tiingo-api-key
TIINGO_API_KEY_2=tiingo-api-key-2
# TIINGO_API_KEY_3=...
# ... add as many as you have, up to the count you need.

# AlgoGators API key
ALGOGATORS_API_KEY=algogators-api-key

# Database credentials
DB_HOST=db-host
DB_PORT=db-port
DB_USER=db-user
DB_PASSWORD=db-password
DB_NAME=db-name